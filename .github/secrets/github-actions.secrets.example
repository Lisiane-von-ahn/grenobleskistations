# Copy this file to:
#   .github/secrets/github-actions.secrets
# Then fill with real values and run:
#   chmod +x deploy/set-github-secrets.sh
#   ./deploy/set-github-secrets.sh .github/secrets/github-actions.secrets your-org/your-repo

SSH_HOST=
SSH_USER=
SSH_PRIVATE_KEY=

DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=grenobleski
DB_PORT=5432

# Optional but supported by deploy/install.sh and workflow:
DATABASE_URL=
WEATHER_API_KEY=
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@grenobleski.local

# Web ads (provider)
ENABLE_WEB_ADS=false
WEB_ADS_PROVIDER=external_script
ADSENSE_CLIENT_ID=
ADSENSE_SLOT_FOOTER=
PROPELLERADS_SCRIPT_SRC=
PROPELLERADS_CONTAINER_ID=
WEB_ADS_SCRIPT_SRC=
WEB_ADS_CONTAINER_ID=
# Example: google.com, pub-1234567890123456, DIRECT, f08c47fec0942fa0
ADS_TXT_CONTENT=
